# Windows dev: `npm run dev` deletes `.next` first to avoid missing chunk errors (e.g. Cannot find module './124.js').
# For faster restarts when stable, use `npm run dev:quick`. Add an antivirus exclusion for `frontend/.next` if issues persist.

# Public URL of Django API (no trailing slash) — used by the browser and image domains
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional: server-side CMS fetches (Docker/internal hostname). Defaults to NEXT_PUBLIC_API_URL.
# CMS_API_URL=http://backend:8000

# Optional: max milliseconds for each server CMS fetch (default 8000). Stops SSR hanging if API is slow.
# CMS_FETCH_TIMEOUT_MS=8000

# Dev: CMS fetches use cache: no-store so admin edits appear on refresh (default in NODE_ENV=development).
# Force no-store in production builds: CMS_FETCH_NO_CACHE=1
# Keep Next fetch cache even in dev (faster, but up to 60s stale): CMS_FETCH_CACHE=1

# Shown in footer, contact page, chat panel
NEXT_PUBLIC_CONTACT_EMAIL=hello@helixprimesolutions.com

# Footer social (optional — set to empty string to hide that icon)
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/your-company
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourhandle
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/yourpage
# NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/yourorg
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/yourprofile
# NEXT_PUBLIC_SOCIAL_WHATSAPP=https://wa.me/15551234567

# Canonical site URL for metadata / Open Graph
NEXT_PUBLIC_SITE_URL=https://helixprimesolutions.com

# Optional: home hero background when Django still uses the built-in default image only.
# Use a public/ path e.g. /hero-bg.jpg or a full https URL. Uploaded CMS hero image always wins.
# NEXT_PUBLIC_HERO_BACKGROUND=/hero-bg.jpg

# Optional: Tawk.to live chat — Property ID and Widget ID from Tawk dashboard
# NEXT_PUBLIC_TAWK_PROPERTY_ID=
# NEXT_PUBLIC_TAWK_WIDGET_ID=
