DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Railway: with RAILWAY_ENVIRONMENT set, *.railway.app / *.up.railway.app / *.railway.internal are added automatically. Add any custom domain here.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Railway / Docker: auto-create first admin on deploy (skipped if a superuser already exists).
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=use-a-long-random-secret
# DJANGO_SUPERUSER_USERNAME=admin

# Gmail SMTP — use an App Password (2FA): https://support.google.com/accounts/answer/185833
# Do not wrap values in quotes unless the quotes are part of the password.
# If email still fails: check Django terminal for "Failed to send inquiry email" and the
# traceback; with DJANGO_DEBUG=true the API may include an "smtp_error" hint in dev.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
# Alternative Gmail: EMAIL_PORT=465, EMAIL_USE_SSL=true, EMAIL_USE_TLS=false
EMAIL_HOST_USER=yourcompany@gmail.com
# No spaces (or spaces are OK—they are stripped): abcdabcdabcdabcd
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=yourcompany@gmail.com
CONTACT_RECIPIENT_EMAIL=yourcompany@gmail.com

# Optional: SMTP connection timeout in seconds (default 30).
# EMAIL_TIMEOUT=30

# Test mail from CLI (same path as the contact form):
#   python manage.py test_contact_email

# Railway: if private DATABASE_URL gives "connection refused" to *.railway.internal, set
# DJANGO_USE_PUBLIC_DATABASE=1 and provide DATABASE_PUBLIC_URL from the Postgres service.
# DJANGO_DATABASE_URL=  # optional full URL override

# Uploaded images are stored under backend/media/ (dev: served automatically when DEBUG=true).
# In production, configure your web server or object storage to serve MEDIA_URL.
